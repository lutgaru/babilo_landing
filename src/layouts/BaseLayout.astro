---
// src/layouts/BaseLayout.astro
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "B | The Future of Local Language Learning" } = Astro.props;
---

<!doctype html>
<html class="dark" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Manrope:wght@300;400;500;600;700&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />



  </head>
  <body
    class="bg-[#111118] text-on-surface font-body-md selection:bg-primary-container selection:text-white"
  >
    <slot />
  </body>
</html>
---
// src/components/HeroSection.astro
---

<section class="max-w-[1440px] mx-auto px-6 mb-32 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">

  <!-- Copy -->
  <div class="lg:col-span-7 space-y-8">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-violet-500/10 border border-violet-500/20 text-secondary font-label-sm">
      <span class="w-2 h-2 rounded-full bg-violet-500 animate-pulse"></span>
      NOW POWERED BY GEMMA 4
    </div>

    <h1 class="font-headline-xl text-white text-[64px] leading-tight max-w-2xl">
      The Future of{" "}
      <span class="bg-gradient-to-r from-rose-400 to-violet-400 bg-clip-text text-transparent">
        Local Language Learning
      </span>
    </h1>

    <p class="font-body-lg text-on-surface-variant max-w-xl">
      Experience zero-latency linguistic fluency with an AI engine that lives entirely on your
      hardware. Privacy by default, powered by Rust, and optimized for local Vulkan acceleration.
    </p>

    <div class="flex flex-wrap gap-4 pt-4">
      <button class="bg-gradient-to-r from-rose-500 to-violet-600 px-8 py-4 rounded-lg font-headline-md text-[18px] text-white glow-crimson active:scale-95 transition-all">
        Get Started
      </button>
      <button class="bg-[#18181f] border border-rose-500/50 px-8 py-4 rounded-lg font-headline-md text-[18px] text-rose-400 hover:bg-rose-500/5 active:scale-95 transition-all">
        View Architecture
      </button>
    </div>
  </div>

  <!-- Visual card -->
  <div class="lg:col-span-5 relative">
    <div class="absolute -top-20 -right-20 w-80 h-80 bg-rose-500/10 blur-[100px] rounded-full"></div>
    <div class="absolute -bottom-20 -left-20 w-80 h-80 bg-violet-500/10 blur-[100px] rounded-full"></div>

    <div class="relative glass-surface p-1 rounded-2xl overflow-hidden shadow-2xl">
      <img
        class="w-full h-[500px] object-cover rounded-xl"
        src="https://lh3.googleusercontent.com/aida-public/AB6AXuAyjwom4-NdqBovMhLzWJRC0NvqEv8IocG7SRsYYczj_RbDabhEkJKfV0RFCumTCQ7Lt3BeQYiS3tKqVVO7QUwcLp1pLwpDVDXC-3fZtG64O3h5z0Bg5wiaTEMz-zmjgaUCPY_Q4Gz4wtNbYoWXS2UgLLOz4FE83d6yPM429oBjk2aEXXg7VsugKLEGNjt7motHSRY8ojC6yeWysvLZ6zIJ0EY5zi7f91wh1sGOpHA21vGlhBnmGth6sJH23cAijlp3UjnGjlCZwWk"
        alt="Neural language interface"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-[#111118] via-transparent to-transparent"></div>

      <!-- Stats overlay -->
      <div class="absolute bottom-6 left-6 right-6 p-4 glass-surface rounded-xl">
        <div class="flex items-center justify-between text-xs font-label-sm text-slate-400 mb-2">
          <span>NEURAL THROUGHPUT</span>
          <span class="text-rose-400">124 tokens/sec</span>
        </div>
        <div class="w-full h-1 bg-white/5 rounded-full overflow-hidden">
          <div class="w-[85%] h-full bg-gradient-to-r from-rose-500 to-violet-500"></div>
        </div>
      </div>
    </div>
  </div>

</section>

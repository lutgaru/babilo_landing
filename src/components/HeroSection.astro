---
// src/components/HeroSection.astro
import Mockup from "./Mockup.astro";
---

<section
  id="home"
  class="max-w-[1440px] mx-auto px-6 mb-32 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center"
>
  <div class="lg:col-span-7 space-y-8">
    <div
      class="inline-flex items-center gap-3 px-3 py-1 rounded-full bg-rose-500/10 border border-rose-500/20 text-rose-400 font-label-sm"
    >
      <span class="relative flex h-2 w-2">
        <span
          class="animate-ping absolute inline-flex h-full w-full rounded-full bg-rose-400 opacity-75"
        ></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-rose-500"
        ></span>
      </span>
      COMING SOON TO STEAM
    </div>

    <h1 class="font-headline-xl text-white text-[64px] leading-tight max-w-2xl">
      The Future of{" "}
      <span
        class="bg-gradient-to-r from-rose-400 to-violet-400 bg-clip-text text-transparent"
      >
        Local Language Learning
      </span>
    </h1>

    <p class="font-body-lg text-slate-400 max-w-xl">
      Master any language with zero-latency AI that lives entirely on your
      hardware. No subscriptions. No cloud. Just raw, private performance
      powered by Gemma 4 and Rust.
    </p>

    <div class="flex flex-col gap-4 pt-4">
      <p class="text-xs font-label-sm text-slate-500 uppercase tracking-widest">
        Join the Alpha Waitlist
      </p>

      <form id="waitlist-form" class="flex flex-wrap gap-3 relative">
        <div class="hidden" aria-hidden="true">
          <input
            type="text"
            name="babilo_internal_id"
            tabindex="-1"
            autocomplete="off"
          />
        </div>

        <input
          type="email"
          name="email"
          id="email-input"
          required
          placeholder="Enter your email"
          class="bg-[#18181f] border border-white/10 px-6 py-4 rounded-lg focus:outline-none focus:border-rose-500/50 min-w-[300px] text-white transition-all disabled:opacity-50"
        />

        <button
          id="submit-btn"
          type="submit"
          class="bg-gradient-to-r from-rose-500 to-violet-600 px-8 py-4 rounded-lg font-headline-md text-[18px] text-white glow-crimson active:scale-95 transition-all disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Secure Early Access
        </button>

        <!-- Turnstile Widget -->
        <div
          class="cf-turnstile"
          data-sitekey={import.meta.env.PUBLIC_TURNSTILE_SITE_KEY}
          data-theme="dark"
        >
        </div>
      </form>

      <p id="form-message" class="text-sm mt-2 hidden"></p>
    </div>
  </div>

  <div class="lg:col-span-5 relative overflow-hidden">
    <!-- ... (resto de tu código del mockup se mantiene igual) ... -->
    <div
      class="absolute -top-20 -right-20 w-80 h-80 bg-rose-500/10 blur-[100px] rounded-full"
    >
    </div>
    <div
      class="absolute -bottom-20 -left-20 w-80 h-80 bg-violet-500/10 blur-[100px] rounded-full"
    >
    </div>

    <div
      class="relative glass-surface p-1 rounded-2xl overflow-hidden shadow-2xl border border-white/5"
    >
      <Mockup />
      <div
        class="absolute inset-0 bg-gradient-to-t from-[#111118] via-transparent to-transparent"
      >
      </div>
      <div
        class="absolute bottom-6 left-6 right-6 p-6 glass-surface rounded-xl border border-white/10 backdrop-blur-md"
      >
        <div
          class="flex items-center justify-between text-[10px] font-label-sm text-slate-400 mb-3 tracking-widest"
        >
          <span>DEVELOPMENT PROGRESS</span>
          <span class="text-violet-400">BUILD 0.9.4-ALPHA</span>
        </div>
        <div class="w-full h-1.5 bg-white/5 rounded-full overflow-hidden mb-4">
          <div
            class="w-[78%] h-full bg-gradient-to-r from-rose-500 to-violet-500"
          >
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <p class="text-[10px] text-slate-500 uppercase">Engine</p>
            <p class="text-sm text-white font-mono">Tauri v2 + Rust</p>
          </div>
          <div>
            <p class="text-[10px] text-slate-500 uppercase">Inference</p>
            <p class="text-sm text-white font-mono">Vulkan/Gemma 4</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer
></script>

<script>
  const form = document.getElementById("waitlist-form") as HTMLFormElement;
  const btn = document.getElementById("submit-btn") as HTMLButtonElement;
  const msg = document.getElementById("form-message");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    // UI Feedback
    btn.disabled = true;
    btn.innerText = "Processing...";

    const formData = new FormData(form);
    const data = {
      email: formData.get("email"),
      hp: formData.get("babilo_internal_id"),
      cf_token: formData.get("cf-turnstile-response"),
    };

    try {
      const response = await fetch("/api/subscribe", {
        method: "POST",
        body: JSON.stringify(data),
        headers: { "Content-Type": "application/json" },
      });

      const result = await response.json();

      if (response.ok) {
        msg?.classList.remove("hidden", "text-rose-400");
        msg?.classList.add("text-emerald-400");
        if (msg) msg.innerText = "Welcome to the Alpha, Adrian!";
        form.reset();
      } else {
        throw new Error(result.message || "Submission failed");
      }
    } catch (err) {
      msg?.classList.remove("hidden", "text-emerald-400");
      msg?.classList.add("text-rose-400");
      if (msg) msg.innerText = "Something went wrong. Try again?";
    } finally {
      btn.disabled = false;
      btn.innerText = "Secure Early Access";
    }
  });
</script>

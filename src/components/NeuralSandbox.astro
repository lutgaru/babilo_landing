---
// src/components/NeuralSandbox.astro

interface WaveBar {
  height: number;
  colorClass: string;
  opacityClass: string;
  pulse: boolean;
}

// Pre-compute all classes in the frontmatter — no logic inside JSX
const rawHeights: number[] = [8, 16, 24, 32, 48, 32, 24, 16, 8, 16, 40, 20, 12];

const waveBars: WaveBar[] = rawHeights.map((h, i) => ({
  height: h * 4,
  colorClass: i >= 4 && i <= 7 ? "bg-violet-500" : "bg-rose-500",
  opacityClass:
    h <= 8  ? "opacity-40" :
    h <= 16 ? "opacity-60" :
    h <= 24 ? "opacity-80" : "",
  pulse: h >= 32,
}));

interface Stat {
  value: string;
  label: string;
  colorClass: string;
}

const stats: Stat[] = [
  { value: "4.2ms",  label: "Latency",    colorClass: "text-rose-500"   },
  { value: "99.8%",  label: "Confidence", colorClass: "text-violet-500" },
];

interface InfoBox {
  label: string;
  value: string;
}

const infoBoxes: InfoBox[] = [
  { label: "PROSODY MODEL", value: "Supertonic-XL v4" },
  { label: "LOCAL RUNTIME", value: "LLM-RS v2.0.4"   },
];
---

<section class="max-w-[1440px] mx-auto px-6 mb-32">

  <div class="text-center mb-12">
    <h2 class="font-headline-lg text-white">Live Neural Sandbox</h2>
    <p class="text-on-surface-variant">Real-time calibration of the local inference engine</p>
  </div>

  <div class="glass-surface rounded-3xl p-1 lg:p-2 max-w-4xl mx-auto overflow-hidden">
    <div class="bg-[#111118] rounded-[22px] p-8">

      <!-- Header row -->
      <div class="flex items-center justify-between mb-12">
        <div class="flex items-center gap-3">
          <div class="w-3 h-3 rounded-full bg-green-500"></div>
          <span class="font-label-sm text-slate-400">HARDWARE ACCELERATED</span>
        </div>
        <div class="flex gap-8">
          {stats.map((s) => (
            <div class="text-center">
              <div class={`font-headline-md text-xl ${s.colorClass}`}>{s.value}</div>
              <div class="text-[10px] text-slate-500 font-label-sm uppercase">{s.label}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Wave visualisation -->
      <div class="h-64 flex items-center justify-center gap-1 mb-12">
        {waveBars.map((bar) => (
          <div
            class={`w-1 rounded-full ${bar.colorClass} ${bar.opacityClass} ${bar.pulse ? "animate-pulse" : ""}`}
            style={`height: ${bar.height}px`}
          ></div>
        ))}
      </div>

      <!-- Info boxes -->
      <div class="grid grid-cols-2 gap-4">
        {infoBoxes.map((box) => (
          <div class="p-4 rounded-xl bg-white/5 border border-white/5">
            <span class="text-[10px] text-slate-500 font-label-sm block mb-1">{box.label}</span>
            <span class="text-white font-headline-md text-sm">{box.value}</span>
          </div>
        ))}
      </div>

    </div>
  </div>

</section>
---
const faqs = [
  {
    question: "How can Babilo run Gemma 4 locally without lag?",
    answer: "We utilize the Vulkan API and custom Rust bindings to orchestrate GPU VRAM directly. By using 4-bit quantization and native multimodal processing, we bypass the heavy overhead of traditional Python-based AI stacks."
  },
  {
    question: "Is it really 'Buy Once, Own Forever'?",
    answer: "Yes. When you purchase Babilo on Steam, you own that version of the engine and weights permanently. No monthly subscriptions, no tokens to buy, and no 'Pro' tiers. Your hardware does the work, so you don't pay us for compute."
  },
  {
    question: "What languages will be supported at launch?",
    answer: "Thanks to Gemma 4's multilingual capabilities and Supertonic's polyglot synthesis, Babilo will launch with full support for Spanish, English, French and German with more being optimized post-launch."
  },
  {
    question: "Does Babilo require an internet connection?",
    answer: "Only for the initial download and Steam updates. Once installed, the entire neural engine, STT, and TTS systems run 100% offline. Your data never touches a cloud server."
  },
  {
    question: "Can I use Babilo if I don't have a high-end Gaming PC?",
    answer: "While a dedicated GPU (NVIDIA/AMD) provides the best experience, our Vulkan-based optimization allows Babilo to run efficiently on modern integrated graphics and Apple Silicon (M-series) chips."
  }
];
---

<section class="max-w-[1000px] mx-auto px-6 mb-32" id="questions">
  <div class="text-center mb-16">
    <h2 class="font-headline-lg text-white mb-4">Frequently Asked Questions</h2>
    <p class="text-slate-400 font-body-md">Clear answers for learners and developers alike.</p>
  </div>

  <div class="space-y-4">
    {faqs.map((faq) => (
      <div class="glass-surface p-6 rounded-2xl border border-white/5 hover:border-violet-500/30 transition-all group">
        <details class="group/item">
          <summary class="flex items-center justify-between cursor-pointer list-none">
            <span class="text-white font-headline-md text-lg pr-4 group-hover/item:text-violet-400 transition-colors">
              {faq.question}
            </span>
            <span class="material-symbols-outlined text-slate-500 group-open:rotate-180 transition-transform">
              expand_more
            </span>
          </summary>
          <div class="mt-4 pt-4 border-t border-white/5 text-slate-400 font-body-md leading-relaxed animate-in fade-in slide-in-from-top-1">
            {faq.answer}
          </div>
        </details>
      </div>
    ))}
  </div>

  <div class="mt-16 p-8 rounded-3xl bg-gradient-to-br from-rose-500/10 to-violet-500/10 border border-white/10 text-center">
    <p class="text-white font-headline-md mb-2">Have a more technical question?</p>
    <p class="text-slate-400 text-sm mb-6">Explore the architecture in our technical manifest or reach out via the waitlist.</p>
    <a href="#waitlist-form" data-scroll-to-waitlist class="inline-block text-rose-400 font-label-sm border-b border-rose-400 pb-1 hover:text-rose-300 transition-colors">
      JOIN THE COMMUNITY
    </a>
  </div>
</section>

<script>
  // ── Scroll + focus al formulario de waitlist ──────────────────────
  document
    .querySelectorAll<HTMLAnchorElement>("[data-scroll-to-waitlist]")
    .forEach((link) => {
      link.addEventListener("click", (e) => {
        e.preventDefault(); // Evita el salto brusco default

        const form = document.getElementById("waitlist-form");
        const emailInput = document.getElementById(
          "email-input",
        ) as HTMLInputElement;

        if (form && emailInput) {
          // 1. Scroll suave con compensación del header fijo
          const headerOffset = 100; // Ajusta según la altura real de tu header
          const elementPosition =
            form.getBoundingClientRect().top + window.scrollY;
          const offsetPosition = elementPosition - headerOffset;

          window.scrollTo({
            top: offsetPosition,
            behavior: "smooth",
          });

          // 2. Enfocar el input después de que termine el scroll (~500ms para smooth)
          setTimeout(() => {
            emailInput.focus();
            // Opcional: seleccionar el texto si ya tiene algo
            // emailInput.select();
          }, 600);

          // 3. Si es mobile, cerrar el menú hamburguesa
          const menu = document.getElementById("mobile-menu");
          const toggle = document.getElementById("menu-toggle");
          const lines = toggle?.querySelectorAll(".burger-line");

          if (menu?.classList.contains("menu-open")) {
            menu.classList.add("max-h-0", "border-white/0");
            menu.classList.remove("max-h-96", "border-white/10");
            toggle?.setAttribute("aria-expanded", "false");
            lines?.[0].classList.remove("rotate-45", "translate-y-[6px]");
            lines?.[1].classList.remove("opacity-0");
            lines?.[2].classList.remove("-rotate-45", "-translate-y-[6px]");
          }
        }
      });
    });
</script>
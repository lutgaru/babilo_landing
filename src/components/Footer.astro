---
// src/components/Footer.astro

interface FooterLink {
  label: string;
  href: string;
}

const links: FooterLink[] = [
  { label: "Documentation", href: "#" },
  { label: "Architecture",  href: "#" },
  { label: "Supertonic API", href: "#" },
  { label: "Security",      href: "#" },
];
---

<footer class="relative bottom-0 w-full mt-20 bg-[#18181f] border-t border-white/5">
  <div class="flex flex-col md:flex-row justify-between items-center w-full px-8 py-12 gap-6 max-w-[1440px] mx-auto">

    <div class="space-y-4">
      <span class="font-serif italic text-3xl text-rose-500">B</span>
      <p class="font-space-grotesk text-sm uppercase tracking-widest text-slate-500">
        © 2024 Language Engine. Powered by Rust &amp; Gemma 4. Built with Tauri.
      </p>
    </div>

    <div class="flex flex-wrap gap-8">
      {links.map((link) => (
        <a
          href={link.href}
          class="text-slate-500 hover:text-white transition-colors font-space-grotesk text-sm uppercase tracking-widest"
        >
          {link.label}
        </a>
      ))}
    </div>

  </div>
</footer>

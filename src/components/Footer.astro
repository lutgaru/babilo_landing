---
// src/components/Footer.astro
import Logo from "../assets/babilologo2.svg";

interface FooterLink {
  label: string;
  href: string;
}

const links: FooterLink[] = [
  { label: "Architecture", href: "#stack" },
  { label: "Tech Manifest", href: "#manifest" },
  { label: "Personal Site", href: "https://lutgaru.com" },
  { label: "GitHub", href: "https://github.com/lutgaru" },
];
---

<footer class="relative bottom-0 w-full mt-20 bg-[#0a0a0f] border-t border-white/5">
  <div class="max-w-[1440px] mx-auto px-8 py-16">
    <div class="flex flex-col md:flex-row justify-between items-start gap-12">
      
      <div class="space-y-6 max-w-md">
        <div class="flex items-center gap-3">
          <Logo width={36} height={36} class="opacity-80" />
          <span class="font-headline-md text-white text-xl tracking-tight">Babilo</span>
        </div>
        
        <p class="font-body-md text-slate-500 leading-relaxed">
          A high-performance, local-first language engine built for privacy and speed. 
          Developed and maintained by <a href="https://lutgaru.com" class="text-rose-400 hover:text-rose-300 transition-colors">Lutgaru Labs</a>.
        </p>

      </div>

    <div class="mt-16 pt-8 border-t border-white/[0.03] flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="font-mono text-[10px] uppercase tracking-widest text-slate-600">
        © 2026 LUTGARU LABS. ALL RIGHTS RESERVED.
      </p>
      
      <div class="flex gap-6">
        <p class="font-mono text-[10px] text-slate-600 uppercase tracking-widest">
          BUILT WITH RUST & TAURI
        </p>
        <p class="font-mono text-[10px] text-slate-600 uppercase tracking-widest">
          GPLV3 LICENSE
        </p>
      </div>
    </div>
  </div>
</footer>
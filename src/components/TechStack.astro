---
const stack = [
  {
    category: "System Core",
    tech: "Rust & Tauri v2",
    details: "Zero-cost abstractions, memory safety without GC, and cross-platform native hooks.",
    metric: "Binary < 20MB",
    color: "rose"
  },
  {
    category: "Neural Engine",
    tech: "Gemma 4 (9B) via llamacpp",
    details: "Native multimodal weights optimized for 4-bit quantization (GGUF).",
    metric: "124 t/sec",
    color: "violet"
  },
  {
    category: "Graphics API",
    tech: "Vulkan SDK",
    details: "Low-level GPU orchestration for hardware-agnostic tensor acceleration.",
    metric: "Sub-10ms Latency",
    color: "rose"
  },
  {
    category: "View Layer",
    tech: "Vite + Lit",
    details: "Reactive Web Components with shadow DOM isolation. No Virtual DOM overhead.",
    metric: "60fps+ UI",
    color: "violet"
  }
];
---

<section class="max-w-[1440px] mx-auto px-6 mb-32">
  <div class="relative group">
    <div class="absolute -inset-1 bg-gradient-to-r from-rose-500/20 to-violet-500/20 rounded-[32px] blur opacity-75 group-hover:opacity-100 transition duration-1000"></div>
    
    <div class="relative bg-[#0d0d12] rounded-[32px] p-8 lg:p-16 border border-white/10">
      <div class="flex flex-col lg:flex-row justify-between items-start gap-12">
        
        <div class="lg:w-1/3">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-slate-400 font-mono text-[10px] mb-6 tracking-[0.2em]">
            SYSTEM_MANIFEST.LOG
          </div>
          <h2 class="font-headline-lg text-white mb-6">Engineered for the Edge</h2>
          <p class="text-slate-400 font-body-md leading-relaxed">
            Babilo isn't just an app; it's a high-performance orchestration layer. We've eliminated the cloud to prove that privacy and state-of-the-art AI can coexist on local silicon.
          </p>
          
          <div class="mt-8 p-4 rounded-xl bg-white/[0.02] border border-white/5">
             <p class="text-[10px] font-mono text-rose-500 mb-2 uppercase tracking-widest">Git Stats</p>
             <div class="flex gap-4">
                <div><span class="text-white font-mono">24k</span> <span class="text-slate-500 text-xs">LOC</span></div>
                <div><span class="text-white font-mono">0</span> <span class="text-slate-500 text-xs">Cloud Deps</span></div>
             </div>
          </div>
        </div>

        <div class="lg:w-2/3 w-full grid grid-cols-1 gap-4">
          {stack.map((item) => (
            <div class="flex items-center justify-between p-6 rounded-2xl bg-white/[0.03] border border-white/5 hover:bg-white/[0.05] transition-all group/item">
              <div class="flex gap-6 items-center">
                <div class={`w-1 h-12 rounded-full ${item.color === 'rose' ? 'bg-rose-500' : 'bg-violet-500'}`}></div>
                <div>
                  <p class="text-[10px] font-mono text-slate-500 uppercase tracking-widest mb-1">{item.category}</p>
                  <h4 class="text-white font-headline-md text-lg">{item.tech}</h4>
                  <p class="text-slate-500 text-sm max-w-md hidden md:block">{item.details}</p>
                </div>
              </div>
              <div class="text-right">
                <span class="font-mono text-xs text-rose-400 bg-rose-400/10 px-3 py-1 rounded-full whitespace-nowrap">
                  {item.metric}
                </span>
              </div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </div>
</section>
---
// src/components/TopAppBar.astro

interface NavLink {
  label: string;
  href: string;
  active?: boolean;
}

const navLinks: NavLink[] = [
  { label: "Engine", href: "#", active: true },
  { label: "Models",   href: "#" },
  { label: "Hardware", href: "#" },
  { label: "Docs",     href: "#" },
];
---

<header class="fixed top-0 z-50 w-full bg-[#111118]/80 backdrop-blur-[20px] border-b border-white/10">
  <div class="flex justify-between items-center w-full px-6 py-4 max-w-[1440px] mx-auto">

    <!-- Logo + Nav -->
    <div class="flex items-center gap-4">
      <span class="font-serif italic text-3xl text-rose-500 drop-shadow-[0_0_8px_rgba(224,68,106,0.3)]">
        B
      </span>
      <nav class="hidden md:flex gap-8 ml-12">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class={
              link.active
                ? "text-rose-500 font-bold font-space-grotesk font-medium tracking-tight text-sm"
                : "text-slate-400 hover:text-rose-400 hover:bg-white/5 transition-all font-space-grotesk font-medium tracking-tight text-sm px-2 py-1 rounded"
            }
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>

    <!-- Actions -->
    <div class="flex items-center gap-4">
      <span class="material-symbols-outlined text-slate-400 cursor-pointer hover:text-white">
        language
      </span>
      <button class="bg-gradient-to-r from-rose-500 to-violet-600 px-6 py-2 rounded-lg font-headline-md text-[14px] hover:brightness-110 active:scale-95 duration-200 ease-out">
        Start
      </button>
    </div>

  </div>
</header>

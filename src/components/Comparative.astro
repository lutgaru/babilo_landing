---
const competitors = [
  {
    name: "Babilo",
    logic: "Local (Gemma 4)",
    privacy: "100% Private",
    latency: "Sub-10ms (Vulkan)",
    cost: "One-time Pay ($)",
    openSource: "Yes",
    highlight: true,
  },
  {
    name: "ChatGPT",
    logic: "Cloud (GPT-4o)",
    privacy: "Data Collected",
    latency: "Network Dep.",
    cost: "$20/mo Forever",
    openSource: "No",
  },
  {
    name: "Duolingo Max",
    logic: "Cloud (LLM)",
    privacy: "Data Collected",
    latency: "Moderate",
    cost: "$30/mo Forever",
    openSource: "No",
  },
  
  {
    name: "Speak",
    logic: "Cloud (GPT-4)",
    privacy: "Data Collected",
    latency: "Network Dep.",
    cost: "$15/mo Forever",
    openSource: "No",
  }
];
---

<section class="max-w-[1440px] mx-auto px-6 mb-32" id="comparative">
  <div class="text-center mb-16">
    <h2 class="font-headline-lg text-white mb-4">Ownership vs. Renting</h2>
    <p class="text-slate-400">Stop paying for permission to speak. Own your engine.</p>
  </div>

  <div class="overflow-x-auto rounded-3xl border border-white/5 bg-[#111118]">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="border-b border-white/5">
          <th class="p-6 text-slate-500 font-label-sm uppercase tracking-wider">Solution</th>
          <th class="p-6 text-slate-500 font-label-sm uppercase tracking-wider">Privacy Model</th>
          <th class="p-6 text-slate-500 font-label-sm uppercase tracking-wider">Latency</th>
          <th class="p-6 text-slate-500 font-label-sm uppercase tracking-wider">Pricing</th>
          <th class="p-6 text-slate-500 font-label-sm uppercase tracking-wider text-center">Open Source</th>
        </tr>
      </thead>
      <tbody class="text-white">
        {competitors.map((c) => (
          <tr class={`transition-colors border-b border-white/5 hover:bg-white/[0.02] ${c.highlight ? 'bg-rose-500/5' : ''}`}>
            <td class="p-6">
              <div class="flex flex-col">
                <span class={`font-headline-md ${c.highlight ? 'text-rose-400' : 'text-white'}`}>
                  {c.name}
                </span>
                <span class="text-[10px] text-slate-500 uppercase tracking-tighter">{c.logic}</span>
              </div>
            </td>
            <td class="p-6">
              <span class={`px-3 py-1 rounded-full text-xs ${c.privacy === '100% Private' ? 'bg-emerald-500/10 text-emerald-400' : 'bg-slate-500/10 text-slate-400'}`}>
                {c.privacy}
              </span>
            </td>
            <td class="p-6 font-mono text-sm">{c.latency}</td>
            <td class="p-6">
              <span class={c.highlight ? 'text-rose-400 font-bold' : 'text-slate-300'}>{c.cost}</span>
            </td>
            <td class="p-6 text-center">
              <span class={`material-symbols-outlined ${c.openSource === 'Yes' ? 'text-emerald-400' : 'text-rose-900'}`}>
                {c.openSource === 'Yes' ? 'check_circle' : 'cancel'}
              </span>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  
  <p class="mt-6 text-center text-slate-600 text-xs italic">
    * Comparative based on current 2026 SaaS subscription benchmarks and local hardware benchmarks using Vulkan.
  </p>
</section>